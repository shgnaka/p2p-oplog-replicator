{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/p2p-oplog/event-schema-v1.json",
  "title": "P2P Oplog Event v1",
  "type": "object",
  "required": [
    "event_id",
    "event_version",
    "merge_strategy",
    "causal",
    "command_schema",
    "command",
    "signature",
    "author",
    "created_at"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_version": { "type": "string", "const": "lww_v1" },
    "merge_strategy": { "type": "string", "const": "lww_tombstone" },
    "causal": {
      "type": "object",
      "required": ["type", "lamport", "node_id"],
      "properties": {
        "type": { "type": "string", "const": "lamport_v1" },
        "lamport": { "type": "integer", "minimum": 0 },
        "node_id": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "command_schema": { "type": "string", "minLength": 1 },
    "command": { "type": "object" },
    "signature": { "type": "string", "minLength": 1 },
    "author": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
